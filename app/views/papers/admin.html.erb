<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= Rails.application.settings['name'] %>: Admin – <%= @paper.title %></title>
  <%= stylesheet_link_tag    'application', media: 'all' %>
  <%= javascript_importmap_tags %>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
</head>
<body>
  <header class="container-fluid">
    <%= render partial: "content/layout/navbar" %>
  </header>

  <div class="container">
    <%= render partial: "shared/flashes" %>
  </div>

  <div class="container paper-show">
    <div class="paper-title" style="margin-bottom: 2em;">
      <div class="paper-meta">
        <h1><%= @paper.title %></h1>
        <span class="small">
          <%= link_to "← Back to paper", @paper.doi? ? @paper.seo_url : paper_path(@paper) %>
        </span>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="row">
      <div class="col-md-9">
        <div class="generic-content-item" style="margin-top: 0;">
          <%= render partial: "papers/status", locals: { paper: @paper } %>
          <%= render partial: "papers/eic_summary", locals: { paper: @paper } %>
          <%= render partial: "papers/notes", locals: { paper: @paper } %>
          <%= render partial: "papers/actions", locals: { paper: @paper } %>
        </div>
      </div>
    </div>
  </div>

  <div class="container-fluid">
    <%= render partial: "content/layout/footer" %>
  </div>
</body>
</html>
